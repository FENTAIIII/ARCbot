<Page
    x:Class="ARCbot.Views.Pages.ConsolePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:ARCbot.Models"
    Title="控制台"
    Loaded="Page_Loaded"
    MaxHeight="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
>

    <Page.Resources>
        <!-- PCL 风格的左侧列表项样式 -->
        <Style x:Key="PclListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Page.Resources>

    <Grid Margin="32,32,32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="24" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：运行中实例列表 ═══ -->
        <Grid Grid.Column="0">
            <!-- 替换为统一的样式 -->
            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Text="运行中的实例"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Margin="4,0,0,16" />

                <ListBox
                    Grid.Row="1"
                    x:Name="RunningInstancesList"
                    ItemsSource="{Binding RunningInstances}"
                    SelectedItem="{Binding SelectedInstance}"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource PclListItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,12,0" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding}" FontSize="14" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock
                    Grid.Row="1"
                    x:Name="NoRunningLabel"
                    Text="暂无运行中的实例"
                    FontSize="13"
                    Opacity="0.5"
                    HorizontalAlignment="Center"
                    Margin="0,40,0,0"
                    Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- ═══ 右侧：控制台区域 ═══ -->
        <Border
            Grid.Column="2"
            CornerRadius="8"
            Background="#1E1E1E"
            BorderBrush="#333333"
            BorderThickness="1"
            ClipToBounds="True">

            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.15" Color="Black" />
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ─── 顶部工具栏 ─── -->
                <Border
                    Grid.Row="0"
                    CornerRadius="7,7,0,0"
                    Padding="16,12"
                    Background="#252526"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#333333">

                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="WindowConsole20" FontSize="18" Foreground="#4CAF50" Margin="0,0,10,0"/>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="#EEEEEE"
                                Text="{Binding SelectedInstance, FallbackValue='未选择实例', TargetNullValue='未选择实例'}" />
                        </StackPanel>

                        <StackPanel
                            DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                            <ui:Button
                                Content="清屏"
                                Icon="{ui:SymbolIcon Delete24}"
                                Appearance="Transparent"
                                Foreground="#CCCCCC"
                                CornerRadius="6"
                                Padding="12,6"
                                FontSize="13"
                                Margin="0,0,8,0"
                                Command="{Binding ClearConsoleCommand}" />

                            <ui:Button
                                Content="强制停止"
                                Icon="{ui:SymbolIcon Stop24}"
                                Appearance="Info"
                                CornerRadius="6"
                                Padding="12,6"
                                FontSize="13"
                                Command="{Binding ForceStopCommand}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ─── 日志输出区 ─── -->
                <ListBox
                    Grid.Row="1"
                    x:Name="ConsoleOutput"
                    ItemsSource="{Binding ConsoleEntries}"
                    Background="Transparent"
                    BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    Padding="12,8">

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ConsoleEntry}">
                            <TextBlock
                                Text="{Binding Display}"
                                FontFamily="Cascadia Code, Consolas, Courier New"
                                FontSize="13"
                                TextWrapping="Wrap"
                                Padding="4,2"
                                Margin="0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#CCCCCC" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Warn}">
                                                <Setter Property="Foreground" Value="#E5C07B" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Error}">
                                                <Setter Property="Foreground" Value="#F44336" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Level}" Value="{x:Static models:LogLevel.Stdin}">
                                                <Setter Property="Foreground" Value="#4CAF50" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock
                    Grid.Row="1"
                    x:Name="NoSelectionHint"
                    Text="← 请在左侧选择一个运行中的实例"
                    FontSize="15"
                    Opacity="0.4"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Visibility="Collapsed" />

                <!-- ─── 底部输入区 ─── -->
                <Border
                    Grid.Row="2"
                    Padding="12"
                    Background="#252526"
                    CornerRadius="7,7,0,0"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#333333">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" CornerRadius="6" Background="#1E1E1E" BorderThickness="1" BorderBrush="#3E3E42">
                            <ui:TextBox
                                x:Name="ConsoleInputBox"
                                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                PlaceholderText="输入控制台指令..."
                                FontFamily="Cascadia Code, Consolas"
                                FontSize="14"
                                Background="Transparent"
                                Foreground="#EEEEEE"
                                BorderThickness="0"
                                Padding="12,8"
                                VerticalContentAlignment="Center"
                                KeyDown="ConsoleInput_KeyDown" />
                        </Border>

                        <ui:Button
                            Grid.Column="1"
                            Content="发送"
                            Icon="{ui:SymbolIcon Send24}"
                            Appearance="Info"
                            CornerRadius="6"
                            Padding="16,8"
                            Margin="12,0,0,0"
                            Command="{Binding SendInputCommand}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
