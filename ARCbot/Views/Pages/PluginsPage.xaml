<Page
    x:Class="ARCbot.Views.Pages.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="插件扩展"
    Loaded="Page_Loaded">

    <Grid Margin="40,48,40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══ 标题 ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />
            <StackPanel Margin="24,16">
                <TextBlock
                    Text="插件扩展"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Margin="0,0,0,4" />
                <TextBlock
                    Text="管理机器人实例的自定义技能插件（.js 文件）"
                    FontSize="14"
                    Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- 其他内容保持不变 -->
        <!-- ═══ 实例选择 + 操作按钮 ═══ -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <!-- 统一背景层 -->
            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

            <!-- 内容层 -->
            <DockPanel Margin="16,12">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <ui:Button
                        Content="📂 导入插件"
                        Appearance="Info"
                        CornerRadius="8"
                        Padding="16,6"
                        FontSize="12"
                        Margin="0,0,8,0"
                        Command="{Binding ImportPluginCommand}" />

                    <ui:Button
                        Content="🔄 刷新"
                        Appearance="Secondary"
                        CornerRadius="8"
                        Padding="16,6"
                        FontSize="12"
                        Margin="0,0,8,0"
                        Command="{Binding RefreshPluginsCommand}" />

                    <ui:Button
                        Content="📖 怎么开发技能？"
                        Appearance="Info"
                        CornerRadius="8"
                        Padding="16,6"
                        FontSize="12"
                        Command="{Binding OpenDevDocsCommand}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Text="选择实例："
                        FontSize="13"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />
                    <ComboBox
                        ItemsSource="{Binding InstanceNames}"
                        SelectedItem="{Binding SelectedInstanceName}"
                        MinWidth="180" />
                </StackPanel>
            </DockPanel>
        </Grid>

        <!-- ═══ 插件列表 ═══ -->
        <Grid Grid.Row="2">
            <!-- 统一背景层 -->
            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

            <!-- 内容层 -->
            <Border CornerRadius="12" BorderThickness="1" BorderBrush="Transparent" Padding="8">
                <ListView
                    ItemsSource="{Binding Plugins}"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalContentAlignment="Stretch">

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                CornerRadius="10"
                                Padding="16,12"
                                Margin="4,2"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}">

                                <DockPanel>
                                    <ui:Button
                                        DockPanel.Dock="Right"
                                        Content="🗑"
                                        Appearance="Secondary"
                                        CornerRadius="8"
                                        Padding="8,4"
                                        FontSize="12"
                                        Command="{Binding DataContext.DeletePluginCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center" />

                                    <Border
                                        DockPanel.Dock="Left"
                                        Width="40" Height="40"
                                        CornerRadius="10"
                                        Background="{StaticResource AccentBrush}"
                                        Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                        <TextBlock
                                            Text="JS"
                                            FontSize="14"
                                            FontWeight="Bold"
                                            Foreground="White"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            Text="{Binding FileName}"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <TextBlock
                                            FontSize="11"
                                            Opacity="0.5"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}">
											<Run Text="{Binding DisplaySize, Mode=OneWay}" />
											<Run Text=" · " />
											<Run Text="{Binding LastModified, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>

        <!-- ═══ 底部状态栏 ═══ -->
        <TextBlock
            Grid.Row="3"
            Text="{Binding StatusMessage}"
            FontSize="12"
            Opacity="0.5"
            Margin="0,8,0,0" />
    </Grid>
</Page>
