<Page
    x:Class="ARCbot.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:ARCbot.Models"
    Title="首页"
    Loaded="Page_Loaded">

    <Page.Resources>
        <!-- 状态到颜色转换 -->
        <Style x:Key="StatusDotStyle" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
    </Page.Resources>

    <Grid Margin="40,48,40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ 顶部标题区 ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,32">
            <!-- 替换为统一的样式 -->
            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />
            <StackPanel Margin="24,16">
                <TextBlock
                    Text="我的机器人"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Margin="0,0,0,4" />
                <TextBlock
                    x:Name="StatusLabel"
                    Text="加载中..."
                    FontSize="14"
                    Opacity="0.6" />
            </StackPanel>
        </Grid>

        <!-- ═══ 实例卡片网格 ═══ -->
        <ScrollViewer
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled"
            Margin="-8,0">

            <ItemsControl
                x:Name="InstancesItemsControl"
                ItemsSource="{Binding Instances}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:BotInstance}">
                        <!-- ─── 单个机器人卡片 ─── -->
                        <Grid Width="320" Margin="8,8,16,24" Cursor="Hand">
                            <Grid.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black" />
                            </Grid.Effect>

                            <!-- 1. 统一背景层 -->
                            <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

                            <!-- 2. 内容与边框层 (保留悬停变色效果，但不设背景色) -->
                            <Border Padding="24" CornerRadius="12" BorderThickness="1" BorderBrush="Transparent" Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <StackPanel>
                                <!-- 实例名 + 状态 -->
                                <DockPanel Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Ellipse Width="10" Height="10" Margin="0,0,6,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Setter Property="Fill" Value="#9E9E9E" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:BotStatus.Running}">
                                                            <Setter Property="Fill" Value="#4CAF50" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:BotStatus.Error}">
                                                            <Setter Property="Fill" Value="#FF5252" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="{x:Static models:BotStatus.Starting}">
                                                            <Setter Property="Fill" Value="#FFC107" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <TextBlock
                                            Text="{Binding Status}"
                                            FontSize="12"
                                            Opacity="0.7"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock
                                        Text="{Binding InstanceName}"
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        TextTrimming="CharacterEllipsis" />
                                </DockPanel>

                                <!-- 服务器信息 -->
                                <TextBlock
                                    FontSize="12"
                                    Opacity="0.5"
                                    Margin="0,0,0,4">
									<Run Text="🌐 " />
									<Run Text="{Binding McHost, Mode=OneWay}" />
									<Run Text=":" />
									<Run Text="{Binding McPort, Mode=OneWay}" />
                                </TextBlock>

                                <TextBlock
                                    FontSize="12"
                                    Opacity="0.5"
                                    Margin="0,0,0,12">
									<Run Text="👤 " />
									<Run Text="{Binding McUsername, Mode=OneWay}" />
									<Run Text=" | " />
									<Run Text="{Binding McAuthType, Mode=OneWay}" />
                                </TextBlock>

                                <!-- 按钮组 -->
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button
                                        Content="▶ 启动"
                                        Appearance="Info"
                                        CornerRadius="8"
                                        Padding="16,6"
                                        FontSize="12"
                                        Margin="0,0,8,0"
                                        Click="StartInstance_Click"
                                        Tag="{Binding}" />

                                    <ui:Button
                                        Content="✏️ 编辑"
                                        Appearance="Secondary"
                                        CornerRadius="8"
                                        Padding="16,6"
                                        FontSize="12"
                                        Margin="0,0,8,0"
                                        Click="EditInstance_Click"
                                        Tag="{Binding}" />

                                    <ui:Button
                                        Content="🗑"
                                        Appearance="Secondary"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        FontSize="12"
                                        Click="DeleteInstance_Click"
                                        Tag="{Binding}" />
                                </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══ 空状态提示 ═══ -->
        <StackPanel
            x:Name="EmptyStatePanel"
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Visibility="Collapsed">
            <TextBlock
                Text="🤖"
                FontSize="64"
                HorizontalAlignment="Center"
                Margin="0,0,0,16" />
            <TextBlock
                Text="还没有机器人实例"
                FontSize="20"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                Opacity="0.6"
                Margin="0,0,0,8" />
            <TextBlock
                Text="点击右下角的 + 按钮创建你的第一个 AI 机器人"
                FontSize="13"
                HorizontalAlignment="Center"
                Opacity="0.4" />
        </StackPanel>

        <!-- ═══ FAB 创建按钮 ═══ -->
        <ui:Button
            Grid.Row="1"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,8,8"
            Width="56"
            Height="56"
            CornerRadius="28"
            Appearance="Info"
            ToolTip="创建新实例"
            Click="CreateInstance_Click"
            Panel.ZIndex="10">
            <ui:SymbolIcon Symbol="Add24" FontSize="28" />
            <ui:Button.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    ShadowDepth="4"
                    Opacity="0.3"
                    Color="#0078D7" />
            </ui:Button.Effect>
        </ui:Button>
    </Grid>
</Page>
