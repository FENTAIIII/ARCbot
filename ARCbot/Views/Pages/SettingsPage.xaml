<Page
    x:Class="ARCbot.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="设置"
    Loaded="Page_Loaded"
    MaxHeight="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">

    <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Disabled"
        Margin="40,48,40,24">

        <StackPanel MaxWidth="800">

            <!-- ═══ 标题 ═══ -->
            <Grid Margin="0,0,0,32">
                <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />
                <TextBlock
                    Text="设置"
                    FontSize="36"
                    FontWeight="Bold"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Margin="24,16" />
            </Grid>

            <!-- ═══ 运行环境 ═══ -->
            <TextBlock Text="运行环境" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Grid Margin="0,0,0,24">
                <!-- 统一背景层 -->
                <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

                <!-- 内容层 -->
                <Border CornerRadius="12" BorderThickness="1" BorderBrush="Transparent">
                    <StackPanel>
                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="Node.js 运行时" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DownloadStatusText}" FontSize="12" Opacity="0.7" Margin="0,4,0,0" />
                                <ProgressBar
                                    x:Name="NodeProgressBar"
                                    Value="{Binding DownloadProgress}"
                                    Maximum="100"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed" />
                            </StackPanel>

                            <ui:Button
                                x:Name="DownloadNodeBtn"
                                Grid.Column="1"
                                Content="下载 Node.js"
                                Appearance="Info"
                                Padding="16,6"
                                Command="{Binding DownloadNodeCommand}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="16,0" Opacity="0.5" />

                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="机器人基础包" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding BaseAgentStatusText}" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                                <ProgressBar
                                    x:Name="BaseProgressBar"
                                    Value="{Binding BaseAgentProgress}"
                                    Maximum="100"
                                    Height="4"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed" />
                            </StackPanel>

                            <ui:Button
                                x:Name="DownloadBaseBtn"
                                Grid.Column="1"
                                Content="下载基础包"
                                Appearance="Info"
                                Padding="16,6"
                                Command="{Binding DownloadBaseAgentCommand}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="16,0" Opacity="0.5" />

                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock Text="自定义基础包" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="导入本地 zip 包作为机器人基础模板" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                                <TextBlock Text="{Binding CustomBaseAgentPath}" FontSize="11" Opacity="0.5" />
                            </StackPanel>

                            <ui:ToggleSwitch
                                Grid.Column="1"
                                Margin="0,0,16,0"
                                IsChecked="{Binding UseCustomBaseAgent}"
                                Content="使用自定义"
                                VerticalAlignment="Center" />

                            <ui:Button
                                Grid.Column="2"
                                Content="导入本地包"
                                Appearance="Secondary"
                                Padding="16,6"
                                Command="{Binding ImportCustomBaseAgentCommand}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ 个性化 ═══ -->
            <TextBlock Text="个性化" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Grid Margin="0,0,0,24">
                <!-- 统一背景层 -->
                <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

                <!-- 内容层 -->
                <Border CornerRadius="12" BorderThickness="1" BorderBrush="Transparent" Padding="16">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="暗色模式" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="切换亮色/暗色主题" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding IsDarkMode}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,0,0,16" Opacity="0.5" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="背景遮罩不透明度" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="数值越低，背景图片越清晰（设为0则完全透出底图）" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                            </StackPanel>

                            <Slider
                                Grid.Column="1"
                                Minimum="0.0"
                                Maximum="1.0"
                                Value="{Binding BgOpacity}"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,0,0,16" Opacity="0.5" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="程序背景" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="选择预设背景或自定义图片" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                            </StackPanel>

                            <ComboBox
                                Grid.Column="1"
                                Width="150"
                                Margin="0,0,8,0"
                                ItemsSource="{Binding PresetImages}"
                                SelectedItem="{Binding BackgroundImagePath}"
                                VerticalAlignment="Center">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <ui:Button
                                Grid.Column="2"
                                Content="自定义图片"
                                Icon="{ui:SymbolIcon Image24}"
                                Command="{Binding SelectCustomImageCommand}"
                                VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>


            <!-- ═══ 关于 ═══ -->
            <TextBlock Text="关于" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,8"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

            <Grid Margin="0,0,0,24">
                <!-- 统一背景层 -->
                <Border Style="{StaticResource UnifiedOverlayBorderStyle}" />

                <!-- 内容层 -->
                <Border CornerRadius="12" BorderThickness="1" BorderBrush="Transparent" Padding="16">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="ARCbot" FontSize="18" FontWeight="Bold" />
                                    <TextBlock
                                        Text="{Binding AppVersion, StringFormat=' v{0}'}"
                                        FontSize="13"
                                        Opacity="0.6"
                                        VerticalAlignment="Bottom"
                                        Margin="4,0,0,2" />
                                </StackPanel>

                                <TextBlock Text="新一代 Minecraft AI 机器人多开启动器" FontSize="12" Opacity="0.6" Margin="0,0,0,8" />

                                <TextBlock FontSize="12" Opacity="0.5" Margin="0,0,0,2">
                                    <Run Text="运行时: " />
                                    <Run Text="{Binding DotNetVersion, Mode=OneWay}" />
                                </TextBlock>

                                <TextBlock FontSize="12" Opacity="0.5">
                                    <Run Text="数据目录: " />
                                    <Run Text="{Binding AppDataPath, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>

                            <ui:Button
                                Grid.Column="1"
                                Content="打开数据目录"
                                Appearance="Secondary"
                                Padding="16,6"
                                Command="{Binding OpenAppDataFolderCommand}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,16" Opacity="0.5" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="启动弹窗" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="禁用启动时的爱发电支持弹窗" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                            </StackPanel>

                            <ui:ToggleSwitch
                                Grid.Column="1"
                                IsChecked="{Binding DisableAfdianPopup}"
                                VerticalAlignment="Center" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="0,16" Opacity="0.5" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="联系作者 Q群1082669385" FontSize="15" FontWeight="SemiBold" />
                                <TextBlock Text="支持我们的开发工作" FontSize="12" Opacity="0.6" Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button
                                    Content="爱发电"
                                    Appearance="Info"
                                    Padding="16,6"
                                    Margin="0,0,8,0"
                                    Command="{Binding OpenAfdianCommand}"
                                    VerticalAlignment="Center" />
                                <ui:Button
                                    Content="GitHub"
                                    Appearance="Secondary"
                                    Padding="16,6"
                                    Command="{Binding OpenGithubCommand}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>
