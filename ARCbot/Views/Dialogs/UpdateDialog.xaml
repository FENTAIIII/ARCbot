<Window x:Class="ARCbot.Views.Dialogs.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本" Height="400" Width="450" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" 
        Topmost="True" Background="#FAFAFA" Foreground="Black">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" Foreground="Black" Margin="0,0,0,10"/>
        
        <!-- 更新日志 -->
        <TextBox x:Name="ReleaseNotesBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" 
                 VerticalScrollBarVisibility="Auto" Margin="0,0,0,15" Padding="5"
                 Background="White" BorderBrush="#DDDDDD" Foreground="Black" />
        
        <!-- 下载进度区域 -->
        <Grid x:Name="DownloadProgressGrid" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar x:Name="DownloadProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
            <TextBlock x:Name="DownloadStatusText" Grid.Row="1" Foreground="#666666" FontSize="12" Margin="0,5,0,0"/>
        </Grid>
        
        <!-- 不再提醒复选框 -->
        <CheckBox x:Name="SkipCheckBox" Grid.Row="3" Foreground="Black" Margin="0,0,0,15">
            <TextBlock Text="跳过此版本（不再提醒）" Foreground="Black" />
        </CheckBox>
        
        <!-- 按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Width="90" Height="30" Margin="0,0,10,0" 
                    Background="White" BorderBrush="#CCCCCC" Click="Cancel_Click">
                <TextBlock Text="暂不更新" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <Button x:Name="UpdateButton" Content="立即更新" Width="90" Height="30" 
                    Background="#0078D7" Foreground="White" BorderThickness="0" Click="Update_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#0078D7"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="0" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#106EBE"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
