<ui:FluentWindow
    x:Class="ARCbot.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:pages="clr-namespace:ARCbot.Views.Pages"
    Title="ARCbot"
    Width="1200" Height="780"
    MinWidth="900" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round">

    <ui:FluentWindow.Resources />

    <Grid>
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Panel.ZIndex="-2" />

        <!-- 左侧半透明遮罩层 (宽度280) -->
        <Border x:Name="BackgroundOverlay" Width="290" HorizontalAlignment="Left" Background="{DynamicResource ApplicationBackgroundBrush}" Opacity="{DynamicResource GlobalOverlayOpacity}" Panel.ZIndex="-1" />

        <!-- ═══ 导航栏与内容区 ═══ -->
        <!-- 新增 Background="Transparent" 去除右侧默认的白色蒙版 -->
        
<ui:NavigationView
            x:Name="RootNavigation"
            Background="Transparent"
            PaneDisplayMode="Left"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleVisible="False"
            OpenPaneLength="280"
            Margin="0,32,0,0"
            Padding="0">
            <ui:NavigationView.PaneHeader>
                <StackPanel Margin="24,0,61,0" Height="63">
                    <TextBlock
                        Text="ARCbot"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                </StackPanel>
            </ui:NavigationView.PaneHeader>

            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem
                    Content="首页"
                    Icon="{ui:SymbolIcon Home24}"
                    TargetPageType="{x:Type pages:HomePage}" />
                <ui:NavigationViewItem
                    Content="控制台"
                    Icon="{ui:SymbolIcon WindowConsole20}"
                    TargetPageType="{x:Type pages:ConsolePage}" />
                <ui:NavigationViewItem
                    Content="插件扩展"
                    Icon="{ui:SymbolIcon PuzzlePiece24}"
                    TargetPageType="{x:Type pages:PluginsPage}" />
                <ui:NavigationViewItem
                    Content="插件市场"
                    Icon="{ui:SymbolIcon StoreMicrosoft24}"
                    TargetPageType="{x:Type pages:MarketPage}" />
                <ui:NavigationViewItem
                    Content="免费体验"
                    Icon="{ui:SymbolIcon Sparkle24}"
                    TargetPageType="{x:Type pages:ExperiencePage}" />
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem
                    Content="帮助文档"
                    Icon="{ui:SymbolIcon QuestionCircle24}"
                    TargetPageType="{x:Type pages:DocsPage}" />
                <ui:NavigationViewItem
                    Content="设置"
                    Icon="{ui:SymbolIcon Settings24}"
                    TargetPageType="{x:Type pages:SettingsPage}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <!-- ═══ 全局微软登录验证弹窗 ═══ -->
        <Border
            x:Name="AuthOverlay"
            Background="#80000000"
            Visibility="Collapsed"
            Opacity="0"
            Panel.ZIndex="999">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                CornerRadius="20"
                Padding="40,32"
                MinWidth="460"
                MaxWidth="540">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.25" Color="Black" />
                </Border.Effect>

                <Border.RenderTransform>
                    <ScaleTransform x:Name="AuthDialogScale" ScaleX="0.9" ScaleY="0.9" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

                <StackPanel>
                    <ui:SymbolIcon
                        Symbol="ShieldKeyhole24"
                        FontSize="48"
                        Foreground="{DynamicResource AccentBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16" />

                    <TextBlock
                        Text="🔐 微软账号验证"
                        FontSize="22"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8" />

                    <TextBlock
                        x:Name="AuthInstanceLabel"
                        Text="来自实例: -"
                        FontSize="13"
                        Opacity="0.6"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20" />

                    <Border
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="12"
                        Padding="24,16"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                        <TextBlock
                            x:Name="AuthCodeText"
                            Text="XXXXXXXX"
                            FontSize="36"
                            FontWeight="Bold"
                            FontFamily="Cascadia Code, Consolas, Courier New"
                            Foreground="{DynamicResource AccentBrush}"
                            HorizontalAlignment="Center" />
                    </Border>

                    <TextBlock
                        Text="请在浏览器中打开微软登录页面，输入上方验证码完成登录。"
                        FontSize="13"
                        Opacity="0.7"
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        Margin="0,0,0,24" />

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,4">

                        <ui:Button
                            x:Name="AuthCopyAndOpenBtn"
                            Content="📋 复制验证码并打开浏览器"
                            Appearance="Info"
                            Click="AuthCopyAndOpen_Click"
                            Padding="20,10"
                            CornerRadius="10"
                            FontSize="14"
                            Margin="0,0,12,0" />

                        <ui:Button
                            x:Name="AuthCloseBtn"
                            Content="关闭"
                            Appearance="Secondary"
                            Click="AuthClose_Click"
                            Padding="20,10"
                            CornerRadius="10"
                            FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ 爱发电弹窗 ═══ -->
        <Border
            x:Name="AfdianOverlay"
            Background="#80000000"
            Visibility="Collapsed"
            Opacity="0"
            Panel.ZIndex="1000">
            <Border
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                CornerRadius="20"
                Padding="40,32"
                MinWidth="460"
                MaxWidth="540">

                <Border.Effect>
                    <DropShadowEffect BlurRadius="32" ShadowDepth="8" Opacity="0.25" Color="Black" />
                </Border.Effect>

                <Border.RenderTransform>
                    <ScaleTransform x:Name="AfdianDialogScale" ScaleX="0.9" ScaleY="0.9" />
                </Border.RenderTransform>
                <Border.RenderTransformOrigin>0.5,0.5</Border.RenderTransformOrigin>

                <StackPanel>
                    <ui:SymbolIcon
                        Symbol="Heart24"
                        FontSize="48"
                        Foreground="#0078D7"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16" />

                    <TextBlock
                        Text="☕ 支持一下作者"
                        FontSize="22"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16" />

                    <TextBlock
                        Text="如果我们的程序对你有帮助的话，能考虑为我们买一杯咖啡吗？没有大家的支持，ARCbot很难保持稳定的维护和更新（难过）。实在不行，GitHub上求个star行嘛"
                        FontSize="14"
                        Opacity="0.8"
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        Margin="0,0,0,12" />

                    <TextBlock
                        Text="（TIPS：该弹窗可以在设置永久关闭）"
                        FontSize="12"
                        Opacity="0.5"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,24" />

                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                        <ui:Button
                            Content="爱发电支持"
                            Appearance="Info"
                            Click="AfdianLink_Click"
                            Padding="20,10"
                            CornerRadius="10"
                            FontSize="14"
                            Margin="0,0,12,0" />

                        <ui:Button
                            Content="GitHub Star"
                            Appearance="Secondary"
                            Click="GithubLink_Click"
                            Padding="20,10"
                            CornerRadius="10"
                            FontSize="14"
                            Margin="0,0,12,0" />

                        <ui:Button
                            Content="但是我拒绝！"
                            Appearance="Secondary"
                            Click="AfdianClose_Click"
                            Padding="20,10"
                            CornerRadius="10"
                            FontSize="14" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- ═══ 标题栏 ═══ -->
        <ui:TitleBar
            Title=""
            ShowMaximize="True"
            ShowMinimize="True"
            CanMaximize="True"
            Background="Transparent"
            Panel.ZIndex="100" />

    </Grid>
</ui:FluentWindow>
